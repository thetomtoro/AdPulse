# AdPulse Environment Configuration

NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Infrastructure provider flags (set to false when using real services)
USE_MEMORY_DB=true
USE_MEMORY_CACHE=true
USE_MEMORY_QUEUE=true

# PostgreSQL (when USE_MEMORY_DB=false)
DATABASE_URL=postgresql://adpulse:adpulse@localhost:5432/adpulse

# TimescaleDB (when USE_MEMORY_DB=false)
TIMESCALE_URL=postgresql://adpulse:adpulse@localhost:5433/adpulse_events

# Redis (when USE_MEMORY_CACHE=false)
REDIS_URL=redis://localhost:6379

# Kafka (when USE_MEMORY_QUEUE=false)
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=adpulse

# Secrets
TRACKING_SECRET=dev-tracking-secret-change-me-in-prod
WEBHOOK_SECRET=dev-webhook-secret-change-me-in-prod

# Rate limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# Logging
LOG_LEVEL=info
