{
  "name": "adpulse",
  "version": "1.0.0",
  "description": "Real-time ad bidding & campaign management API",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "db:migrate": "tsx scripts/migrate.ts",
    "seed": "tsx scripts/seed.ts",
    "simulate": "tsx scripts/simulate-traffic.ts",
    "benchmark": "tsx scripts/benchmark-bidding.ts"
  },
  "dependencies": {
    "fastify": "^4.28.0",
    "@fastify/swagger": "^8.15.0",
    "@fastify/swagger-ui": "^4.1.0",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/cors": "^9.0.0",
    "zod": "^3.23.0",
    "kafkajs": "^2.2.4",
    "ioredis": "^5.4.0",
    "pg": "^8.12.0",
    "pino": "^9.3.0",
    "pino-pretty": "^11.2.0",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "vitest": "^1.6.0",
    "@vitest/coverage-v8": "^1.6.0",
    "tsx": "^4.16.0",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.0"
  }
}
